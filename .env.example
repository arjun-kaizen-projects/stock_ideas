# ─────────────────────────────────────────────
#  SanDisk Radar — Environment Configuration
# ─────────────────────────────────────────────

# REQUIRED: Your Anthropic API key
# Get one free at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL: Your email for SEC EDGAR user-agent header (required by SEC)
CONTACT_EMAIL=your@email.com

# OPTIONAL: Secret token to protect the /api/scan endpoint
# If set, POST /api/scan requires header: x-scan-secret: YOUR_SECRET
SCAN_SECRET=

# OPTIONAL: Server port (default 3000)
PORT=3000
